# ============================================================
# OffenSecOps — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=offensecops
POSTGRES_USER=offensecops_user
POSTGRES_PASSWORD=your_strong_password_here

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── JWT (minimum 32 characters) ──────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_minimum_32_characters_here

# ── Default Admin (auto-created on first run) ─────────────────
DEFAULT_ADMIN_PASSWORD=Admin123!

# ── Grafana (optional monitoring) ────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password_here

# ── Constructed URLs ─────────────────────────────────────────
# These are auto-constructed from variables above in docker-compose
# Uncomment and fill manually if needed
# DATABASE_URL=postgresql+asyncpg://offensecops_user:your_strong_password_here@postgres:5432/offensecops
# REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# ── OSINT API Keys (optional) ────────────────────────────────
# Get free API key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Get API key at: https://securitytrails.com/app/account/credentials
SECURITYTRAILS_API_KEY=

# Get API token at: https://search.censys.io/account/api
CENSYS_API_TOKEN=

# Get API key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
